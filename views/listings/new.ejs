<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>new entry</title>
</head>
<body>
    <h1>create a new listing</h1>
    <form method="post" action="/listings">
        <input type="text" name="title" placeholder="enter title"><br>
        <input name="description" type="text" placeholder="enter description"><br>
        <input type="text" name="image" placeholder="enter URL link"><br>
        <input type="number" name="price" placeholder="enter amount"><br>
        <input type="text" name="location" placeholder="enter location"><br>
        <input type="text" name="country" placeholder="enter country"><br>
        <button>add</button>
    </form>
</body>
</html>